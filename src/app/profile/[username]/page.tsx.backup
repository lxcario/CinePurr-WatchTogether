                                    : `linear-gradient(145deg, ${vipProfileBg}cc 0%, ${vipProfileBg}44 100%)`)
                                  : undefined
                              }
                              nameColor={vipCardNameGradient ? undefined : (vipCardNameColor || (vipNameGradient ? undefined : vipNameColor))}
