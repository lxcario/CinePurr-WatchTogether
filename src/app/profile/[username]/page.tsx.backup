                            <Type size={16} className="text-amber-500" /> ProfileCard Name Style
                          </h4>
                          <p className={`text-xs mb-3 ${isDarkMode ? 'text-gray-400' : 'text-gray-600'}`}>
                            Customize your name color specifically for your ProfileCard (separate from chat)
                          </p>

                          {/* ProfileCard Name Color */}
                          <div className="mb-4">
                            <label className={`block text-xs font-medium mb-2 ${isDarkMode ? 'text-gray-300' : 'text-gray-600'}`}>Name Color</label>
                            <div className="flex gap-2">
                              <input
                                type="color"
                                value={vipCardNameColor || '#ffffff'}
                                onChange={(e) => setVipCardNameColor(e.target.value)}
                                className="w-12 h-10 rounded-lg border-2 cursor-pointer shadow-inner"
                                style={{ borderColor: isDarkMode ? '#374151' : '#d1d5db' }}
                              />
                              <input
                                type="text"
                                value={vipCardNameColor}
                                onChange={(e) => setVipCardNameColor(e.target.value)}
                                placeholder="#ffffff"
                                className={`flex-1 px-3 py-2 rounded-lg text-sm transition-all focus:ring-2 focus:ring-amber-500 outline-none ${
                                  isDarkMode 
                                    ? 'bg-gray-700 text-white border border-gray-600' 
                                    : 'bg-white text-gray-800 border border-gray-200'
                                }`}
                              />
                              <button
                                type="button"
                                onClick={() => setVipCardNameColor('')}
                                className={`px-4 py-2 text-xs font-medium rounded-lg transition-all ${
                                  isDarkMode 
                                    ? 'bg-gray-700 hover:bg-gray-600 text-gray-300' 
                                    : 'bg-gray-200 hover:bg-gray-300 text-gray-600'
                                }`}
                              >
                                Reset
                              </button>
                            </div>
                          </div>

                          {/* ProfileCard Name Gradient */}
                          <div className="mb-4">
                            <label className={`block text-xs font-medium mb-2 ${isDarkMode ? 'text-gray-300' : 'text-gray-600'}`}>Name Gradient</label>
                            <div className="flex gap-2">
                              <input
                                type="color"
                                value={vipCardNameGradient?.split(',')[0]?.trim() || '#ff0080'}
                                onChange={(e) => {
                                  const color2 = vipCardNameGradient?.split(',')[1]?.trim() || '#8000ff';
                                  setVipCardNameGradient(`${e.target.value}, ${color2}`);
                                }}
                                className="w-10 h-10 rounded-lg border-2 cursor-pointer shadow-inner"
                                style={{ borderColor: isDarkMode ? '#374151' : '#d1d5db' }}
                              />
                              <input
                                type="color"
                                value={vipCardNameGradient?.split(',')[1]?.trim() || '#8000ff'}
                                onChange={(e) => {
