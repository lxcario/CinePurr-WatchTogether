                                    type="checkbox"
                                    checked={idCardShowScanlines}
                                    onChange={(e) => setIdCardShowScanlines(e.target.checked)}
                                    className="w-5 h-5 accent-amber-500 rounded"
                                  />
                                  <span className={`font-medium ${isDarkMode ? 'text-gray-200' : 'text-gray-700'}`}>Show Scanlines Effect</span>
                                </label>
                              </div>
                            </div>

                            {/* ID Card Preview */}
                            <div className="mt-4">
                              <p className={`text-sm mb-3 ${isDarkMode ? 'text-gray-400' : 'text-gray-500'}`}>👀 ID Card Preview:</p>
                              <div className={`flex justify-center p-4 rounded-xl ${isDarkMode ? 'bg-gray-900' : 'bg-gray-800'}`}>
                                <IDCard
                                  username={profile.name}
                                  title={profile.isFounder ? 'Founder' : (profile.isVIP ? 'VIP' : 'Member')}
                                  level={Math.floor(profile.watchTime / 3600) + 1}
                                  xp={profile.watchTime % 3600}
                                  maxXp={3600}
                                  avatarUrl={`/api/avatar/${profile.name}`}
                                  cardStyle={idCardStyle}
                                  customAccent={idCardCustomAccent || undefined}
                                  showLevel={idCardShowLevel}
                                  showXpBar={idCardShowXp}
                                  showHologram={idCardShowHologram}
                                  showScanlines={idCardShowScanlines}
                                  size="lg"
                                />
                              </div>
                            </div>
                          </>
                        ) : null}
                      </div>
                    ) : null}

                    {vipMessage && (
                      <div className={`mt-4 p-4 text-center font-medium rounded-xl ${vipMessage.includes('success') ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`}>
                        {vipMessage}
                      </div>
                    )}

                    <button
                      type="button"
                      disabled={isVipLoading}
                      onClick={async () => {
                        setIsVipLoading(true);
                        setVipMessage('');
                        try {
                          const res = await fetch('/api/user/vip', {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ 
                              vipNameColor, 
                              vipFont, 
                              vipBadge, 
                              vipGlow,
                              vipNameEffect,
                              vipNameGradient,
                              vipProfileBg,
                              vipProfileBanner,
                              vipProfileAccent,
                              vipProfileBorder,
                              vipProfileGlow,
                              // ProfileCard name settings
                              vipCardNameColor,
                              vipCardNameGradient,
                              vipCardNameGlow,
                              // ID Card settings
                              profileCardStyle,
                              idCardStyle,
                              idCardCustomHeader,
                              idCardCustomBody,
                              idCardCustomAccent,
                              idCardCustomBorder,
                              idCardShowLevel,
                              idCardShowXp,
                              idCardShowHologram,
                              idCardShowScanlines,
                            }),
                          });
                          if (!res.ok) throw new Error('Failed to save');
                          setVipMessage('VIP settings saved successfully! ✨');
                        } catch (err) {
                          setVipMessage('Failed to save VIP settings');
                        } finally {
                          setIsVipLoading(false);
                        }
                      }}
                      className="w-full mt-6 py-4 font-semibold text-white rounded-xl shadow-lg hover:shadow-xl transition-all bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-600 hover:to-orange-600 flex items-center justify-center gap-2"
                    >
                      {isVipLoading ? 'Saving...' : <><Crown size={20} /> Save VIP Settings</>}
                    </button>
                  </div>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
