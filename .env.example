# CinePurr Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/CinePurr?schema=public"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -hex 32"
NEXTAUTH_URL="http://localhost:3000"

# TMDB API (server-side only - do NOT prefix with NEXT_PUBLIC_)
TMDB_API_KEY="your-tmdb-api-key"

# Email (Resend)
RESEND_API_KEY="your-resend-api-key"
# Sender address - must be a verified sender/domain in your Resend account
# onboarding@resend.dev only works for your own Resend account email (testing)
RESEND_FROM_EMAIL="CinePurr <noreply@yourdomain.com>"

# Optional: Redis
REDIS_URL="redis://localhost:6379"

# Optional: CORS (comma-separated origins for production)
# CORS_ORIGIN="https://yourdomain.com"

# Optional: IPTV proxy allowlist (comma-separated hostnames).
# When set, the proxy will ONLY fetch from these hosts; all others return 400.
# Leave unset during development; set in production to lock down the proxy.
# Example: IPTV_PROXY_ALLOWED_HOSTS="iptv.provider1.com,streams.provider2.net"
# IPTV_PROXY_ALLOWED_HOSTS=

# Optional: Public tunnel (development only, never enable in production)
# ALLOW_PUBLIC_TUNNEL="1"

# Optional: Skip email verification (development only)
# SKIP_EMAIL_VERIFICATION="true"

# Optional: Logging
# LOG_LEVEL="debug"
