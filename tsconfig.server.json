{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es2020",
        "types": [
            "node"
        ],
        "noEmit": false,
        "outDir": "./dist",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false
    },
    "include": [
        "server/**/*.ts",
        "src/lib/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        ".next"
    ]
}